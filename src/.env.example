APP_NAME="RAG"
APP_VERSION="0.0.1"
OPENAI_API_KEY=""

FILE_ALLOWED_TYPES=["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document","text/plain"]
FILE_MAX_SIZE=10485760  # 10 MB in bytes
FILES_DEFAULT_CHUNK_SIZE=512000  # 500 KB in bytes

MONGODB_URL="mongodb://username:password@localhost:27017"
MONGODB_DB_NAME="mini_rag_db"

GENERATION_BACKEND="Ollama"
EMBEDDING_BACKEND="Ollama"

OLLAMA_API_URL="http://localhost:11434/v1"
GENERATION_MODEL_ID="llama3.2"
EMBEDDING_MODEL_ID="nomic-embed-text"
EMBEDDING_SIZE=768

VECTOR_DB_PROVIDER="QDRANT"
VECTOR_DB_PATH="./vectordb_storage"
VECTOR_DB_DISTANCE_METHOD="cosine"